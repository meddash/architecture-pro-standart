@startuml
title Онлайн-кредитный процесс - диаграмма компонентов
top to bottom direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 10
}

actor "Новый клиент" as NewClient
actor "Клиент\nинтернет-банка" as DigitalClient
actor "Сотрудник\nотделения" as BranchEmployee
actor "Менеджер\nкредитного подразделения" as CreditManager

package "Сайт банка" {
  rectangle "Web UI сайта" as SiteUI
  rectangle "Backend сайта" as SiteBackend
}

package "Интернет-банк" {
  rectangle "Web/Mobile UI" as IbUI
  rectangle "Backend интернет-банка" as IbBackend
  rectangle "Модуль СМС-\nподтверждения" as OtpModule
}

package "Цифровой кредитный контур" {
  rectangle "Сервис кредитных\nзаявок" as LoanAppService
  rectangle "Сервис предложений\nи read-модели" as OfferService
  rectangle "Скоринговый адаптер" as ScoringAdapter
  rectangle "Интеграционный слой\nк кредитному конвейеру" as ConveyorGateway
  rectangle "Интеграционный слой\nк АБС" as AbsGateway
  rectangle "Сервис уведомлений" as NotifyService
  database "БД заявок и статусов" as LoanDb
}

rectangle "Кредитный конвейер" as Conveyor
rectangle "Система кредитного\nскоринга" as Scoring
rectangle "АБС банка" as ABS
rectangle "SMS-платформа банка" as SmsPlatform

NewClient --> SiteUI : подаёт заявку
SiteUI --> SiteBackend : HTTPS
SiteBackend --> LoanAppService : создать заявку

DigitalClient --> IbUI : видит предложения,\nподаёт заявку
IbUI --> IbBackend : HTTPS
IbBackend --> OfferService : получить предложения
IbBackend --> OtpModule : запросить подтверждение
OtpModule --> SmsPlatform : отправить / проверить код
IbBackend --> LoanAppService : создать заявку

LoanAppService --> LoanDb : хранить заявки,\nстатусы, историю
LoanAppService --> ScoringAdapter : запросить скоринг\nпо правилам
ScoringAdapter --> Scoring : API скоринга
LoanAppService --> ConveyorGateway : передать цифровую заявку
ConveyorGateway --> Conveyor : заявка,\nприоритет, обновления статусов

LoanAppService --> AbsGateway : клиентские данные,\nидентификатор заявки,\nпродолжение в отделении
AbsGateway --> ABS : чтение / запись\nнужных данных

LoanAppService --> NotifyService : события статусов
NotifyService --> SmsPlatform : СМС-уведомления

OfferService --> IbBackend : предодобренные предложения
OfferService --> LoanAppService : признак ускоренного маршрута

BranchEmployee --> ABS : работа в отделении
CreditManager --> Conveyor : принятие решения

note right of LoanAppService
Единая точка входа
для цифровых заявок
и источник статусов
end note

note right of ConveyorGateway
Новый цифровой маршрут
в кредитный конвейер
в обход суточного обмена
из АБС
end note

@enduml

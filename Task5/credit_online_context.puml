@startuml
title Онлайн-кредитный процесс - диаграмма контекста
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 10
}

actor "Новый клиент" as NewClient
actor "Клиент\nинтернет-банка" as DigitalClient
actor "Сотрудник\nотделения" as BranchEmployee
actor "Менеджер\nкредитного подразделения" as CreditManager

rectangle "Сайт банка" as Site
rectangle "Интернет-банк" as IB
rectangle "Цифровой кредитный контур" as CreditContour
rectangle "Кредитный конвейер" as Conveyor
rectangle "Система кредитного\nскоринга" as Scoring
rectangle "АБС банка" as ABS
rectangle "SMS-платформа банка" as SMS

NewClient --> Site : подаёт заявку,\nполучает предварительное решение
DigitalClient --> IB : видит предложения,\nподаёт заявку
BranchEmployee --> ABS : продолжает заявку\nв отделении
CreditManager --> Conveyor : рассматривает заявку

Site --> CreditContour : кредитная заявка
IB --> CreditContour : кредитная заявка,\nСМС-подтверждение
CreditContour --> Scoring : online scoring /\nупрощённый повторный скоринг
CreditContour --> Conveyor : цифровая заявка,\nприоритет, статусы
CreditContour --> ABS : данные клиента,\nпродолжение процесса в отделении
CreditContour --> SMS : уведомления о статусах
IB --> SMS : проверка СМС-кода

note right of CreditContour
Принимает цифровые заявки,
хранит статусы,
публикует предложения
и маршрутизирует
обработку в банковский контур
end note

@enduml

@startuml
title MVP открытия депозитов - диаграмма контекста
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 10
}

actor "Новый клиент" as NewClient
actor "Клиент\nинтернет-банка" as DigitalClient
actor "Менеджер\nкол-центра" as CallAgent
actor "Менеджер\nбэк-офиса депозитов" as BackOffice
actor "Сотрудник\nотделения" as BranchEmployee

rectangle "MVP открытия депозитов" as System {
  rectangle "Цифровой депозитный контур" as DigitalDeposit
}

rectangle "Сайт банка" as Site
rectangle "Интернет-банк" as IB
rectangle "Система кол-центра" as CallCenter
rectangle "АБС банка" as ABS
rectangle "SMS-платформа банка" as SMS

NewClient --> Site : смотрит депозиты,\nоставляет заявку
DigitalClient --> IB : смотрит ставки,\nподаёт заявку,\nподтверждает по СМС
CallAgent --> CallCenter : работает с лидами
BackOffice --> DigitalDeposit : подтверждает условия заявки
BranchEmployee --> ABS : завершает процесс\nдля новых клиентов

Site --> DigitalDeposit : заявка нового клиента
IB --> DigitalDeposit : заявка действующего клиента
DigitalDeposit --> CallCenter : лид для обзвона
DigitalDeposit --> ABS : открытие депозита,\nстатусы, договор
DigitalDeposit --> SMS : события уведомлений
IB --> SMS : запрос проверки СМС-кода

note right of DigitalDeposit
Хранит заявки, статусы,
историю обработки,
работает со ставками
и интеграцией с АБС
end note

@enduml

@startuml
title MVP открытия депозитов - диаграмма контейнеров
top to bottom direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam rectangle {
  RoundCorner 10
}

actor "Новый клиент" as NewClient
actor "Клиент\nинтернет-банка" as DigitalClient
actor "Менеджер\nкол-центра" as CallAgent
actor "Менеджер\nбэк-офиса депозитов" as BackOffice
actor "Сотрудник\nотделения" as BranchEmployee

package "Сайт банка" {
  rectangle "Web UI сайта" as SiteUI
  rectangle "Backend сайта" as SiteBackend
}

package "Интернет-банк" {
  rectangle "Web/Mobile UI" as IbUI
  rectangle "Backend интернет-банка" as IbBackend
  rectangle "Модуль подтверждения\nопераций" as IbOtp
}

package "Новые сервисы MVP депозитов" {
  rectangle "Сервис заявок\nна депозиты" as DepositApp
  rectangle "Сервис ставок" as RateService
  rectangle "Рабочее место\nбэк-офиса" as BackOfficeUI
  rectangle "Сервис уведомлений" as NotifyService
  rectangle "Интеграционный слой\nк АБС" as AbsGateway
  database "БД заявок" as AppDb
  database "БД ставок" as RateDb
}

package "Система кол-центра" {
  rectangle "UI кол-центра" as CallCenterUI
  rectangle "Backend кол-центра" as CallCenterBackend
}

package "АБС банка" {
  rectangle "Клиентский профиль" as AbsCustomer
  rectangle "Депозитный модуль" as AbsDeposit
  rectangle "Договорный контур" as AbsContract
}

rectangle "SMS-платформа банка" as SmsPlatform

NewClient --> SiteUI : оформляет заявку
SiteUI --> SiteBackend : HTTPS
SiteBackend --> DepositApp : создать лид/заявку

DigitalClient --> IbUI : подаёт заявку
IbUI --> IbBackend : HTTPS
IbBackend --> IbOtp : инициировать\nподтверждение
IbOtp --> SmsPlatform : отправить / проверить СМС-код
IbBackend --> RateService : получить общие\nи персональные ставки
IbBackend --> DepositApp : создать заявку

CallAgent --> CallCenterUI : обрабатывает лид
CallCenterUI --> CallCenterBackend : HTTPS
DepositApp --> CallCenterBackend : передать лид\nнового клиента

BackOffice --> BackOfficeUI : подтверждает условия
BackOfficeUI --> DepositApp : читать / обновлять заявку
DepositApp --> AppDb : хранить заявки,\nстатусы, историю
RateService --> RateDb : хранить ставки
BackOfficeUI --> RateService : управлять ставками
RateService --> DepositApp : ставка по заявке
RateService --> IbBackend : ставки для клиента
RateService --> SiteBackend : публичные ставки

DepositApp --> AbsGateway : команда на открытие\nдепозита и запрос статусов
AbsGateway --> AbsCustomer : данные клиента
AbsGateway --> AbsDeposit : открыть депозит
AbsGateway --> AbsContract : создать договор

DepositApp --> NotifyService : события статусов
NotifyService --> SmsPlatform : отправить СМС

BranchEmployee --> AbsDeposit : завершение процесса\nв отделении

note right of DepositApp
Ключевой контейнер MVP:
- единая точка входа заявок
- статусы и история
- маршрут в кол-центр,
  бэк-офис и АБС
end note

note right of AbsGateway
Изолирует цифровой контур
от внутренних интерфейсов АБС
и снижает связанность
end note

@enduml
